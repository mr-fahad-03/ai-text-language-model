{
  "name": "ai-text-language-model",
  "version": "1.0.0",
  "description": "High-performance English ↔ Arabic translation microservice using ONNX models",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "download-models": "node scripts/download-models.js",
    "postinstall": "node scripts/download-models.js",
    "setup": "npm install && npm run download-models"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mr-fahad-03/ai-text-language-model.git"
  },
  "keywords": [
    "translation",
    "arabic",
    "english",
    "nllb",
    "transformers",
    "onnx",
    "huggingface",
    "machine-learning",
    "nlp"
  ],
  "author": "Muhammad Fahad",
  "license": "MIT"
}
